<html xmlns:o="urn:schemas-microsoft-com:office:office"
xmlns:w="urn:schemas-microsoft-com:office:word"
xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta charset="utf-8">
<style>
body { font-family: Calibri, Arial, sans-serif; font-size: 9pt; margin: 0.5in; }
h1 { font-size: 14pt; text-align: center; margin-bottom: 4pt; }
h2 { font-size: 10pt; margin-top: 8pt; margin-bottom: 2pt; border-bottom: 1px solid #333; }
table { border-collapse: collapse; width: 100%; margin-bottom: 6pt; font-size: 8pt; }
th { background-color: #2c3e50; color: white; padding: 3pt 4pt; text-align: left; font-size: 8pt; }
td { border: 1px solid #ccc; padding: 2pt 4pt; font-size: 8pt; }
tr:nth-child(even) { background-color: #f2f2f2; }
.header-row td { font-weight: bold; }
.note { font-size: 7pt; color: #666; margin-top: 4pt; }
.section { margin-bottom: 6pt; }
p { margin: 2pt 0; font-size: 8.5pt; }
@page { size: 8.5in 11in; margin: 0.5in; }
</style>
</head>
<body>

